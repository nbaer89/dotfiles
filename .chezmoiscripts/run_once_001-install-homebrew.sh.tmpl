{{ if and (eq .chezmoi.os "linux") (not (stat "/etc/NIXOS")) -}}
#!/usr/bin/env bash
# Installs Homebrew on non-NixOS Linux if not already present.
# run_once — Homebrew updates itself via `brew update`.
set -e

if command -v brew &>/dev/null; then
  echo "Homebrew already installed, skipping"
  exit 0
fi

echo "==> Installing Homebrew..."
/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

# Add brew to PATH for the rest of this script
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# Install brew dependencies not handled by the installer
sudo apt-get install -y build-essential 2>/dev/null || true

echo "==> Homebrew installed successfully"
{{ end -}}
