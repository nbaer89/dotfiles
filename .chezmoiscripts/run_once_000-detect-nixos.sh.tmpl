{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# Detects NixOS and writes isNixOS=true to local chezmoi config.
# run_once — only fires on first chezmoi apply on this machine.
if [ -f /etc/NIXOS ]; then
  mkdir -p "$HOME/.config/chezmoi"
  cat > "$HOME/.config/chezmoi/chezmoi.toml" << TOML
[data]
  isNixOS = true
TOML
  echo "chezmoi: NixOS detected — set isNixOS=true"
fi
{{ end -}}
